# Rebuilt inside the image
**/node_modules
**/dist

# Mobile-only / local state (workspace manifests must stay for frozen-lockfile)
**/.expo
apps/mobile/ios
apps/mobile/android

# USDA bulk-import inputs (~217MB): admin-tool only, never built into the image.
# Gitignored too, so a git-based deploy never sees them — this is for local
# `docker build`, which would otherwise send them to the daemon as context.
apps/admin/data

# Repo/local tooling
.git
.claude
.fallow
.vscode
Dockerfile
.dockerignore
docker-compose.yml

# Secrets and noise
**/.env
**/.env.*
!**/.env.example
**/*.log
**/.DS_Store
**/.metro-health-check*
**/*.tsbuildinfo
