# Copy to apps/api/.env for local development (matches docker-compose.yml).
DATABASE_URL=postgres://metabolizm:metabolizm@localhost:5432/metabolizm
PORT=3000

# Better Auth. Generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-secret-change-me-0000000000000000
BETTER_AUTH_URL=http://localhost:3000

# Social sign-in (optional — leave unset and only email/password is enabled).
# Apple: native Sign in with Apple. For the app-only flow both values are the
# iOS bundle identifier (apps/mobile/app.json → ios.bundleIdentifier).
#APPLE_CLIENT_ID=com.anonymous.metabolizmrn
#APPLE_APP_BUNDLE_IDENTIFIER=com.anonymous.metabolizmrn
# Google: the WEB OAuth client (native idTokens carry it as their audience).
#GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=xxxxxxxx
