enum base_unit {
  g
  ml
}

enum food_source {
  system
  custom
}

enum meal {
  breakfast
  lunch
  dinner
  snack
}

enum visibility {
  private
  public
}

table accounts {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  account_id text [not null]
  provider_id text [not null]
  access_token text
  refresh_token text
  id_token text
  access_token_expires_at "timestamp with time zone"
  refresh_token_expires_at "timestamp with time zone"
  scope text
  password text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'accounts_user_id_idx']
    (provider_id, account_id) [name: 'accounts_provider_account_uq', unique]
  }
}

table diary_entries {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  entry_date date [not null]
  meal meal [not null]
  food_id uuid
  name text [not null]
  serving_label text [not null]
  quantity "numeric(8, 3)"
  unit_label text
  unit_amount_in_base "numeric(10, 3)"
  energy_kcal "numeric(8, 2)" [not null]
  protein_g "numeric(8, 2)" [not null]
  carbs_g "numeric(8, 2)" [not null]
  fat_g "numeric(8, 2)" [not null]
  nutrients jsonb [not null, default: `{}`]
  verified boolean [not null, default: false]
  logged_at "timestamp with time zone" [not null, default: `now()`]
  version bigint [not null, default: 1]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    (user_id, entry_date) [name: 'diary_entries_user_date_idx']
    (user_id, updated_at, id) [name: 'diary_entries_user_updated_idx']
  }
}

table food_portions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  food_id uuid [not null]
  label text [not null]
  quantity "numeric(8, 3)" [not null, default: 1]
  amount_in_base "numeric(10, 3)" [not null]
  is_default boolean [not null, default: false]

  indexes {
    food_id [name: 'food_portions_food_id_idx']
  }
}

table foods {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  owner_id uuid
  name text [not null]
  brand text
  description text
  barcode text
  source_ref text
  source food_source [not null, default: 'custom']
  base_unit base_unit [not null, default: 'g']
  serving_size "numeric(8, 2)" [not null, default: 100]
  serving_label text
  energy_kcal "numeric(8, 2)" [not null]
  protein_g "numeric(8, 2)" [not null]
  carbs_g "numeric(8, 2)" [not null]
  fat_g "numeric(8, 2)" [not null]
  nutrients jsonb [not null, default: `{}`]
  visibility visibility [not null, default: 'private']
  is_verified boolean [not null, default: false]
  popularity integer [not null, default: 0]
  forked_from uuid
  version bigint [not null, default: 1]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    owner_id [name: 'foods_owner_id_idx']
    name [name: 'foods_name_trgm_idx']
    barcode [name: 'foods_barcode_active_uq', unique]
    source_ref [name: 'foods_source_ref_active_uq', unique]
  }
}

table sessions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token text [not null]
  expires_at "timestamp with time zone" [not null]
  ip_address text
  user_agent text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'sessions_user_id_idx']
    token [name: 'sessions_token_uq', unique]
  }
}

table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email text [not null, unique]
  name text [not null]
  email_verified boolean [not null, default: false]
  image text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table verifications {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  identifier text [not null]
  value text [not null]
  expires_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    identifier [name: 'verifications_identifier_idx']
  }
}

ref accounts_user_id_users_id_fk: accounts.user_id > users.id [delete: cascade, update: no action]

ref diary_entries_user_id_users_id_fk: diary_entries.user_id > users.id [delete: cascade, update: no action]

ref diary_entries_food_id_foods_id_fk: diary_entries.food_id > foods.id [delete: set null, update: no action]

ref food_portions_food_id_foods_id_fk: food_portions.food_id > foods.id [delete: cascade, update: no action]

ref foods_owner_id_users_id_fk: foods.owner_id > users.id [delete: cascade, update: no action]

ref foods_forked_from_foods_id_fk: foods.forked_from > foods.id [delete: set null, update: no action]

ref sessions_user_id_users_id_fk: sessions.user_id > users.id [delete: cascade, update: no action]