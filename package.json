{
  "name": "metabolizm",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "start": "pnpm --filter mobile start",
    "ios": "pnpm --filter mobile ios",
    "android": "pnpm --filter mobile android",
    "api": "pnpm --filter @metabolizm/shared build && pnpm --filter api start:dev",
    "api:build": "pnpm --filter api... build",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @metabolizm/shared build && pnpm -r exec tsc --noEmit"
  }
}
